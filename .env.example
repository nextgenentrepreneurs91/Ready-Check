
```dotenv
# =============================================================================
# ReadyCheck — Environment Variables Example
# Copy this file to .env and fill in real values before running any service.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=development
LOG_LEVEL=info
PORT=3000

# -----------------------------------------------------------------------------
# WEB APP (apps/web — Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=ReadyCheck
NEXT_PUBLIC_APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# ADMIN APP (apps/admin — Vite)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:4000/api
VITE_APP_NAME=ReadyCheck Admin
VITE_APP_ENV=development

# -----------------------------------------------------------------------------
# MOBILE APP (apps/mobile — Expo)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api
EXPO_PUBLIC_WS_URL=ws://localhost:4000
EXPO_PUBLIC_APP_NAME=ReadyCheck
EXPO_PUBLIC_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/0000000

# -----------------------------------------------------------------------------
# API GATEWAY (services/api-gateway — NestJS)
# -----------------------------------------------------------------------------
API_PORT=4000
API_PREFIX=api
API_VERSION=v1
API_RATE_LIMIT_TTL=60
API_RATE_LIMIT_MAX=120
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://readycheck_user:readycheck_pass@localhost:5432/readycheck_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# -----------------------------------------------------------------------------
# REDIS (caching, queues, pub/sub)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d
SESSION_SECRET=change_this_session_secret

# Google OAuth (coordinator and volunteer login)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# -----------------------------------------------------------------------------
# GOOGLE WORKSPACE (services/google-workspace)
# -----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_EMAIL=readycheck-service@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./secrets/google-service-account.json
GOOGLE_WORKSPACE_DOMAIN=yourorg.com
GOOGLE_DELEGATED_ADMIN_EMAIL=admin@yourorg.com

# Google Forms (assessment delivery)
GOOGLE_FORMS_ENABLED=true
GOOGLE_FORMS_RESPONSE_WEBHOOK_SECRET=your_forms_webhook_secret_here

# Google Meet (briefing rooms)
GOOGLE_MEET_ENABLED=true
GOOGLE_CALENDAR_ID=primary

# Google Drive (document storage)
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_google_drive_folder_id_here

# -----------------------------------------------------------------------------
# GEMINI AI (services/ai-orchestrator + services/google-workspace)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TEMPERATURE=0.4
GEMINI_TOP_P=0.9
GEMINI_GROUNDING_ENABLED=true
GEMINI_SAFETY_THRESHOLD=BLOCK_MEDIUM_AND_ABOVE

# AI Orchestrator service
AI_ORCHESTRATOR_PORT=5001
AI_ORCHESTRATOR_TIMEOUT_MS=30000
AI_ORCHESTRATOR_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# GOOGLE MAPS / GEOLOCATION (services/google-workspace/maps)
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_GEOCODING_ENABLED=true
GOOGLE_MAPS_DIRECTIONS_ENABLED=true
GOOGLE_MAPS_PLACES_ENABLED=true
GEOFENCE_DEFAULT_RADIUS_METERS=5000
ROUTE_INTELLIGENCE_ENABLED=true

# -----------------------------------------------------------------------------
# STORAGE (file uploads, plan documents)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=gcs
GCS_BUCKET_NAME=readycheck-assets-dev
GCS_PROJECT_ID=your-gcp-project-id
GCS_KEY_PATH=./secrets/gcs-service-account.json
STORAGE_MAX_FILE_SIZE_MB=25
STORAGE_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain

# -----------------------------------------------------------------------------
# READINESS ENGINE (services/readiness-engine)
# -----------------------------------------------------------------------------
READINESS_ENGINE_PORT=5002
READINESS_PASS_THRESHOLD=0.75
READINESS_NEEDS_ATTENTION_THRESHOLD=0.50
READINESS_MAX_RETRY_ATTEMPTS=3
READINESS_CHECK_TIMEOUT_SECONDS=120
COGNITIVE_ASSESSMENT_WEIGHT=0.40
EXPERIENCE_WEIGHT=0.30
ROLE_FIT_WEIGHT=0.30

# -----------------------------------------------------------------------------
# TRUST ENGINE (services/trust-engine)
# -----------------------------------------------------------------------------
TRUST_ENGINE_PORT=5003
TRUST_SCORE_MIN=0
TRUST_SCORE_MAX=100
TRUST_DECAY_DAYS=90
CROSS_NGO_FEEDBACK_WEIGHT=0.35
DEPLOYMENT_HISTORY_WEIGHT=0.40
EVENT_RATING_WEIGHT=0.25
NGO_TRUST_MINIMUM_DEPLOYMENTS=3

# -----------------------------------------------------------------------------
# DEPLOYMENT GATE
# -----------------------------------------------------------------------------
DEPLOYMENT_GATE_ENABLED=true
DEPLOYMENT_REQUIRE_ALL_CRITICAL_ROLES=true
DEPLOYMENT_BLOCK_ON_UNVERIFIED=true
DEPLOYMENT_OVERRIDE_REQUIRES_COORDINATOR=true
DEPLOYMENT_OVERRIDE_AUDIT_LOG=true

# -----------------------------------------------------------------------------
# NOTIFICATIONS
# -----------------------------------------------------------------------------
NOTIFICATIONS_ENABLED=true
FCM_SERVER_KEY=your_firebase_cloud_messaging_server_key_here
FCM_PROJECT_ID=your-firebase-project-id
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM_ADDRESS=noreply@readycheck.app
EMAIL_FROM_NAME=ReadyCheck

# SMS (optional, for field volunteer alerts)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+10000000000

# -----------------------------------------------------------------------------
# LOGGING & OBSERVABILITY
# -----------------------------------------------------------------------------
LOG_FORMAT=json
LOG_LEVEL=info
SENTRY_DSN=https://your_sentry_dsn_here@sentry.io/0000000
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
DATADOG_API_KEY=your_datadog_api_key_here
DATADOG_SERVICE_NAME=readycheck-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
FEATURE_AI_ASSISTANT=true
FEATURE_OFFLINE_SYNC=true
FEATURE_DEPLOYMENT_GATE=true
FEATURE_TRUST_SCORES=true
FEATURE_REGIONAL_HISTORY=true
FEATURE_COLLABORATION_REQUESTS=true
FEATURE_NGO_NETWORK=true
FEATURE_WHITEBOARD_INTEGRATION=false

# -----------------------------------------------------------------------------
# OFFLINE SYNC (apps/mobile)
# -----------------------------------------------------------------------------
OFFLINE_SYNC_INTERVAL_SECONDS=30
OFFLINE_QUEUE_MAX_SIZE=500
OFFLINE_RETRY_MAX_ATTEMPTS=5

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=change_this_to_a_32_char_hex_encryption_key_000
BCRYPT_SALT_ROUNDS=12
HELMET_ENABLED=true
CSP_ENABLED=true
RATE_LIMIT_ENABLED=true

# -----------------------------------------------------------------------------
# CI / DEPLOYMENT
# -----------------------------------------------------------------------------
DEPLOY_ENVIRONMENT=development
K8S_NAMESPACE=readycheck-dev
DOCKER_REGISTRY=gcr.io/your-gcp-project-id
IMAGE_TAG=latest
HEALTH_CHECK_PATH=/api/health
HEALTH_CHECK_TIMEOUT_MS=5000
```
